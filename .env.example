# Скопируй в .env и заполни значения

# Medusa secrets (обязательно поменяй в продакшене!)
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# Publishable API Key из Medusa Admin → Settings → API Keys
VITE_MEDUSA_PUBLISHABLE_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Регион по умолчанию
VITE_DEFAULT_REGION=uz

# CORS — замени на реальный домен/IP сервера
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:9000,http://localhost:3000
